APP_NAME=安信合同管理系统
APP_VERSION=1.0.0

# MySQL 配置
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=contract_user
MYSQL_PASSWORD=change-this-db-password
MYSQL_DATABASE=contract_manage

# JWT 安全配置
# 生产环境请务必修改为复杂的随机字符串（至少32位）
# 生成方法: openssl rand -base64 32
SECRET_KEY=replace-with-at-least-32-char-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# 文件上传目录
UPLOAD_DIR=uploads

# 管理员账号配置
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
ADMIN_EMAIL=admin@example.com

# 审计管理员账号配置
AUDIT_ADMIN_USERNAME=auditadmin
AUDIT_ADMIN_PASSWORD=change-this-audit-admin-password
AUDIT_ADMIN_EMAIL=audit@example.com
